# Build output
bin/
obj/

# Visual Studio / Rider
.vs/
.idea/
*.user
*.suo
*.userprefs

# NuGet
packages/
*.nuget.props
*.nuget.targets

# Runtime-generated state (recreated on launch)
data/
runs/

# Bundled panel — large binaries / runtime state are not in git.
# panel/README.md is tracked; everything else is bundled at install time.
panel/PureRAT.exe
panel/Settings.json
panel/Settings.json.purecrack-backup
panel/data.pak
panel/data/
# Track PluginSDK.dll so the EmbeddedResource in csproj resolves on clean clone
panel/Plugins/*
!panel/Plugins/PluginSDK.dll
panel/Clients/
panel/runs/

# Stubs accidentally produced into project root during testing
*.exe
!**/bin/**/*.exe

# OS
Thumbs.db
.DS_Store
